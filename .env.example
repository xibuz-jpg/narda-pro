# ─────────────────────────────────────────────────────────────
# Narda Pro — environment template. Copy to `.env` and fill in.
# NEVER commit the real .env. Secrets go through a vault in prod.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
TZ=UTC

# ── API (NestJS) ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=3000
API_GLOBAL_PREFIX=api
API_CORS_ORIGINS=http://localhost:5173,https://web.telegram.org

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=narda
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=narda
# Prisma connection string (assembled from the vars above)
DATABASE_URL=postgresql://narda:change_me_in_prod@localhost:5432/narda?schema=public

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ── Auth / JWT ────────────────────────────────────────────────
# Use long random values (openssl rand -base64 48) — rotate periodically.
JWT_ACCESS_SECRET=replace_with_strong_random_secret
JWT_ACCESS_TTL=900          # 15 minutes (seconds)
JWT_REFRESH_SECRET=replace_with_another_strong_secret
JWT_REFRESH_TTL=2592000     # 30 days (seconds)

# ── Telegram ──────────────────────────────────────────────────
# From @BotFather. The bot token is used to validate Mini App initData.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# initData signatures older than this (seconds) are rejected (replay protection)
TELEGRAM_INITDATA_MAX_AGE=86400

# ── Payments (primary rail: Telegram Stars) ───────────────────
TELEGRAM_STARS_ENABLED=true
# Local providers (added in a later phase; leave blank for now)
PAYME_MERCHANT_ID=
CLICK_MERCHANT_ID=

# ── Observability ─────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info
PROMETHEUS_ENABLED=true

# ── Security / rate limiting ──────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120
# 32-byte key (hex) for encrypting sensitive columns at rest
ENCRYPTION_KEY=
