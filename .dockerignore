# Never ship the secret env into the image (Render injects env vars at runtime).
.env

# Build artefacts and deps are rebuilt inside the image.
**/node_modules
**/dist
**/build
**/.turbo
**/*.tsbuildinfo

# Local/dev cruft and logs.
.git
.github
**/coverage
*.log
cf.log
cf.out
api-run.log
api-err.log
apps/web/node_modules/.vite

# Local-only helpers.
start-tunnel.ps1
docker-compose.yml
